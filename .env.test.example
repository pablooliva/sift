# Test Environment Configuration for E2E Tests (SPEC-024)
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.test: cp .env.test.example .env.test
# 2. Update any values specific to your test environment (URLs, passwords, etc.)
# 3. Never commit .env.test to version control (it's in .gitignore)
#
# This file provides test-specific values that override production settings.
# Use this with: docker compose -f docker-compose.test.yml --env-file .env.test up -d
#
# Values here are optimized for testing, not production usage.

# ============================================================================
# API KEYS (inherited from production .env - no change needed)
# ============================================================================
# These are loaded from .env via shell environment before Docker Compose runs.
# If you need to use different keys for testing, uncomment and set them here:
# TOGETHERAI_API_KEY=your_test_key
# FIRECRAWL_API_KEY=your_test_key

# ============================================================================
# TEST-SPECIFIC SETTINGS (different from production)
# ============================================================================

# RAG Settings - more permissive for testing
# Production uses 0.7, but tests need lower threshold to match test documents
RAG_SIMILARITY_THRESHOLD=0.3
RAG_SEARCH_WEIGHTS=0.3

# Embedding model and dimension - must match (nomic-embed-text=768)
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSION=768

# LLM Model - use same as production for consistent behavior
RAG_LLM_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# Enable Graphiti for tests (required for SPEC-034 rate limiting tests)
GRAPHITI_ENABLED=true

# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================
# Update this URL to match your Ollama instance
# For Docker containers, use host IP (not localhost)
OLLAMA_API_URL=http://host.docker.internal:11434
OLLAMA_CLASSIFICATION_MODEL=llama3.2-vision:11b
OLLAMA_VISION_MODEL=llama3.2-vision:11b

# ============================================================================
# CHUNK SETTINGS (same as production)
# ============================================================================
CHUNK_ENABLED=true
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_SEARCH_RESULT=3

# ============================================================================
# DEBUG MODE
# ============================================================================
DEBUG=True

# ============================================================================
# NEO4J CONFIGURATION (for Graphiti knowledge graph)
# ============================================================================
# Test credentials - different from production for isolation
NEO4J_URI=bolt://neo4j-test:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_test_password

# ============================================================================
# GRAPHITI CONFIGURATION
# ============================================================================

# Graphiti LLM Model (for entity extraction)
# Uses Together AI API (same as production)
# Updated 2026-02-15: Llama 3.1 deprecated, using Qwen3-Next-80B (matches RAG model)
GRAPHITI_LLM_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# Graphiti Small LLM Model (for reranking and simple tasks)
# Using Qwen2.5 7B Turbo (matches production)
GRAPHITI_SMALL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# Graphiti Embedding Model (for entity and document embeddings)
# Uses Ollama nomic-embed-text (768 dims, matches txtai, same as production)
GRAPHITI_EMBEDDING_MODEL=nomic-embed-text
GRAPHITI_EMBEDDING_DIM=768

# Graphiti Rate Limiting & Batching (SPEC-034)
# More aggressive batching for faster tests
GRAPHITI_BATCH_SIZE=3
GRAPHITI_BATCH_DELAY=45
GRAPHITI_MAX_RETRIES=3
GRAPHITI_RETRY_BASE_DELAY=10
SEMAPHORE_LIMIT=5
