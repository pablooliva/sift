{
  "mcpServers": {
    "txtai": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/path/to/txtai-mcp",
        "txtai_rag_mcp.py"
      ],
      "env": {
        "_comment_txtai": "Replace YOUR_SERVER_IP with txtai server address",
        "TXTAI_API_URL": "http://YOUR_SERVER_IP:8300",
        "TOGETHERAI_API_KEY": "your-together-ai-api-key",
        "RAG_SEARCH_WEIGHTS": "0.5",
        "RAG_SIMILARITY_THRESHOLD": "0.5",
        "_comment_neo4j": "⚠️ SECURITY: Use SSH tunnel (bolt://localhost:7687) or TLS (bolt+s://). See README 'Neo4j Security Setup'",
        "_comment_neo4j_setup": "Run: ssh -L 7687:localhost:7687 user@YOUR_SERVER_IP -N -f",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "your-neo4j-password",
        "_comment_ollama": "Ollama API endpoint (uses server IP, not localhost)",
        "OLLAMA_API_URL": "http://YOUR_SERVER_IP:11434",
        "_comment_timeout": "Graphiti query timeout in seconds (default: 10)",
        "GRAPHITI_SEARCH_TIMEOUT_SECONDS": "10"
      }
    }
  }
}
