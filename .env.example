# txtai Docker Compose Environment Configuration
# Copy this file to .env and fill in your values

# FireCrawl API Configuration (for web scraping in frontend)
# Get your API key from: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_api_key_here

# txtai API Configuration
#  - The API URL is static and must be set to a URL that the Streamlit server (running in Docker) can reach
#  - It should be the IP/hostname that works for all your access scenarios
#  - Using your LAN IP (192.168.0.**) allows access from:
#    - The server itself (can reach its own LAN IP)
#    - Other devices on your local network
#    - Remote access via Tailscale (Tailscale routes to your LAN)
TXTAI_API_URL=http://192.168.0.*:8300

# PostgreSQL Configuration
# Database credentials for document content storage
# Change POSTGRES_USER and POSTGRES_PASSWORD for any non-local deployment
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=txtai

# Qdrant Configuration
QDRANT_URL=http://localhost:7333

# Application Settings (optional - defaults are set in docker-compose.yml)
DEBUG=False
MAX_FILE_SIZE_MB=100
MAX_BATCH_SIZE_MB=500
SEARCH_RESULTS_PER_PAGE=20

# Media Processing Settings (for audio/video transcription)
# Whisper model size: tiny, base, small, medium, large
# Smaller models are faster but less accurate; 'small' is recommended for MVP
WHISPER_MODEL=small
# Maximum media duration in minutes (longer files will be rejected)
MAX_MEDIA_DURATION_MINUTES=30

# Image Processing Settings
# Maximum image file size in MB
IMAGE_MAX_SIZE_MB=20
# Maximum image dimension (width or height) in pixels - larger images are resized
IMAGE_MAX_DIMENSION=4096

# Ollama Configuration (SPEC-019 Phases 1, 2, 3)
# Local Ollama instance for document classification, image captioning, and embeddings
# Uses host IP for Docker container access (not localhost)
OLLAMA_API_URL=http://192.168.0.*:11434
OLLAMA_CLASSIFICATION_MODEL=llama3.2-vision:11b
OLLAMA_VISION_MODEL=llama3.2-vision:11b
# Embedding model and dimension - these must match!
# Available models:
#   - nomic-embed-text: 768 dimensions, 8192 token context (recommended)
#   - mxbai-embed-large: 1024 dimensions, 512 token context
#   - bge-m3: 1024 dimensions, 8192 token context (has NaN bugs - avoid)
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSION=768

# Document Chunking Configuration
# Long documents are split into chunks for better embedding and search quality
# Each chunk gets its own embedding, allowing full document searchability
#
# CHUNK_ENABLED: Set to 'false' to disable chunking (not recommended)
# CHUNK_SIZE: Target chunk size in characters (~375 tokens at 4 chars/token)
#   - Must fit within embedding model context: mxbai-embed-large = 512 tokens (~2000 chars)
#   - Default 1500 leaves headroom for overlap and tokenization variance
# CHUNK_OVERLAP: Characters of overlap between chunks for context continuity
# MAX_CHUNKS_PER_SEARCH_RESULT: Limit chunks from same parent in search results
#
# If switching embedding models, adjust CHUNK_SIZE based on model's context window:
#   - mxbai-embed-large (512 tokens): CHUNK_SIZE=1500 (current)
#   - nomic-embed-text (8192 tokens): CHUNK_SIZE=6000-8000 possible
#   - all-MiniLM-L6-v2 (256 tokens): CHUNK_SIZE=750
CHUNK_ENABLED=true
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_SEARCH_RESULT=3

# Together AI Configuration (for LLM/RAG)
# Get your API key from: https://api.together.ai/settings/api-keys
TOGETHERAI_API_KEY=

# LLM Model Selection (used by BOTH frontend RAG and txtai backend)
# Browse models at: https://api.together.ai/models
#
# This variable configures:
#   1. Frontend RAG (Ask page) - Direct API calls from Streamlit
#   2. txtai backend LLM - Used by txtai workflows, extractive QA, etc.
#
# Recommended models for RAG:
# - Qwen/Qwen3-Next-80B-A3B-Instruct (default) - ~$1.5/M tokens, 262K context, BEST for RAG
# - meta-llama/Llama-3.3-70B-Instruct-Turbo - $0.88/M tokens, 128K context
# - deepseek-ai/DeepSeek-R1-0528 - $0.55 in/$2.19 out, excellent for RAG, 74% cache discount
# - Qwen/Qwen2.5-72B-Instruct-Turbo (deprecated) - 32K context, outdated
RAG_LLM_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# Maximum tokens in LLM response (affects cost and answer length)
RAG_MAX_TOKENS=500

# Temperature for LLM generation (0.0-1.0)
# Lower = more factual/deterministic, Higher = more creative
# For RAG, keep low (0.1-0.3) for accuracy
RAG_TEMPERATURE=0.3

# RAG Search Configuration
# Hybrid search weights: 0.0 = pure semantic, 1.0 = pure keyword (BM25), 0.5 = balanced
# Lower values (0.0-0.4) favor semantic understanding, higher values (0.6-1.0) favor exact keyword matches
RAG_SEARCH_WEIGHTS=0.5

# Similarity threshold: minimum score for a document to be included in RAG context (0.0-1.0)
# Higher values (0.6-0.8) return only highly relevant docs, lower values (0.3-0.5) are more permissive
# Set higher to filter out weakly related documents
RAG_SIMILARITY_THRESHOLD=0.5

# Maximum characters per document in RAG context
# Default: 10000 chars (~2500 tokens) optimized for 131k context models like Qwen2.5-72B
# With 5 docs, this uses ~12,500 tokens, leaving 118k for prompts/response
# Adjust based on your model's context window and cost/latency preferences
# - 5000 = Conservative, faster, cheaper
# - 10000 = Balanced (recommended)
# - 20000 = More context, may improve quality for complex docs
RAG_MAX_DOCUMENT_CHARS=10000

# Manual Document Categories
# Comma-separated list of categories for manual document classification
# These appear as checkboxes in the Upload page and filters in the Browse page
MANUAL_CATEGORIES=reference,technical,personal,research

# Category Colors (for Browse page badges)
# Format: category:color,category:color (hex colors)
CATEGORY_COLORS=reference:#4A90E2,technical:#50C878,personal:#9B59B6,research:#E74C3C

# Graphiti Knowledge Graph Integration (SPEC-021 - Experimental)
# Enable parallel integration of Graphiti temporal knowledge graph alongside txtai
# When enabled, documents are indexed in both txtai (semantic search) and Graphiti (entity graph)
# Search results show side-by-side comparison of both systems
# IMPORTANT: Requires Neo4j service running (see docker-compose.yml)
#
# To enable:
# 1. Set GRAPHITI_ENABLED=true
# 2. Start Neo4j: docker compose --profile graphiti up -d neo4j
# 3. Restart frontend: docker compose restart frontend
GRAPHITI_ENABLED=false

# Neo4j Configuration (required if GRAPHITI_ENABLED=true)
# Default credentials for development - CHANGE IN PRODUCTION
# Access Neo4j Browser at: http://localhost:7474
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Graphiti LLM Model (for entity extraction)
# Recommended: 70B+ parameter models for accurate entity/relationship extraction
# Must be a Together AI model (uses same API key as RAG)
# Current: Qwen/Qwen3-Next-80B-A3B-Instruct (matches RAG model)
# - 262K context window (2x Llama 3.3's 128K)
# - MoE architecture: 80B params, 3B active (efficient)
# - Superior performance for entity extraction and relationship discovery
# AVOID smaller models (<70B) - they may produce malformed JSON or miss entities
GRAPHITI_LLM_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# Graphiti Small LLM Model (for reranking and simple tasks)
# A smaller, faster model used for cross-encoder reranking
# Recommended options (all available on Together AI):
# - Qwen/Qwen2.5-7B-Instruct-Turbo (default) - $0.30/1M, replaces deprecated Meta-Llama-3.1-8B
# - meta-llama/Llama-3-8B-Instruct-Lite - $0.10/1M, cheapest (INT4 quantized)
GRAPHITI_SMALL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# Graphiti Embedding Model (for entity and document embeddings)
# SPEC-035: Uses Ollama's OpenAI-compatible endpoint instead of Together AI
# Reduces API calls by ~42% and improves performance (local embeddings)
# Model must match txtai's OLLAMA_EMBEDDINGS_MODEL for consistency
# Options:
# - nomic-embed-text (768 dims, default, matches txtai, fast local embeddings)
# - Previous: BAAI/bge-base-en-v1.5 (Together AI, deprecated 2026-02-08)
GRAPHITI_EMBEDDING_MODEL=nomic-embed-text
GRAPHITI_EMBEDDING_DIM=768

# Graphiti Rate Limiting & Batching (SPEC-034)
# Controls API call rate to prevent Together AI rate limit errors (429/503)
# Each document chunk triggers 12-15 LLM calls; large documents (100+ chunks) require throttling
#
# SEMAPHORE_LIMIT: Within-episode LLM call concurrency (Graphiti SDK native)
# - Lower = fewer parallel API calls per chunk (more conservative)
# - Higher = faster processing but higher API rate pressure
# - Default: 5 (down from 20 to reduce burst rate)
# - Recommended range: 3-10 (balance speed vs rate limits)
SEMAPHORE_LIMIT=5
#
# GRAPHITI_BATCH_SIZE: Number of chunks to process before pausing
# - Lower = more frequent pauses (more conservative)
# - Higher = faster uploads but higher rate limit risk
# - Default: 3
# - Recommended range: 2-5
GRAPHITI_BATCH_SIZE=3
#
# GRAPHITI_BATCH_DELAY: Base seconds to wait between batches (adaptive may adjust)
# - Provides recovery time for Together AI dynamic rate limits
# - Default: 45 (relies on Together AI's 2x dynamic scaling)
# - Recommended range: 30-60
GRAPHITI_BATCH_DELAY=45
#
# GRAPHITI_MAX_RETRIES: Maximum retry attempts for failed chunks
# - 0 = no retry (not recommended)
# - Higher = more resilient but slower on persistent failures
# - Default: 3
# - Recommended range: 2-5
GRAPHITI_MAX_RETRIES=3
#
# GRAPHITI_RETRY_BASE_DELAY: Base seconds for exponential backoff retry
# - Delay doubles each retry: base, base*2, base*4, etc.
# - Default: 10
# - Recommended range: 5-15
GRAPHITI_RETRY_BASE_DELAY=10

# GRAPHITI_SEARCH_TIMEOUT_SECONDS: Timeout for knowledge graph search queries
# - Default: 10
# - Increase if search queries time out on large graphs
GRAPHITI_SEARCH_TIMEOUT_SECONDS=10

# Automated Backup Configuration (SPEC-042)
# Configuration for scheduled backups to external drive via cron
#
# Setup:
# 1. Set BACKUP_EXTERNAL_DIR to your external drive backup location
# 2. Run: ./scripts/setup-cron-backup.sh (installs cron entries)
# 3. Backups run daily at 3 AM + catch-up every 6 hours if needed
#
# BACKUP_EXTERNAL_DIR: Directory on external drive for backup archives
# - REQUIRED for automated backups
# - Must be on an external/mounted drive (not root filesystem)
# - Will be validated before each backup (mount check + write test)
# - Example: /media/user/ExternalDrive/txtai_backups
# - SECURITY: Should be on encrypted drive (e.g., LUKS) for credential protection
#   - .env file (with API keys) is included in backups
#   - Auto-unlock NOT recommended (physical security trade-off)
BACKUP_EXTERNAL_DIR=/path/to/external/backups

# BACKUP_RETENTION_DAYS: Number of days to keep old backups (optional)
# - Default: 30 days
# - Set to 0 to disable retention (keep all backups)
# - Retention runs AFTER successful backup creation
# - Only affects backups in BACKUP_EXTERNAL_DIR (not manual backups)
# - Calculation: backups older than N days are deleted
BACKUP_RETENTION_DAYS=30